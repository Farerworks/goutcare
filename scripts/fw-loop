#!/usr/bin/env bash
set -euo pipefail

PROJECT="${1:-}"
if [[ -z "$PROJECT" ]]; then
  echo "Usage: ./scripts/fw-loop <project>"
  exit 1
fi

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

MAKEPATCH="$ROOT/scripts/fw-makepatch"
PATCH="$ROOT/scripts/fw-patch"
VALIDATE="$ROOT/scripts/fw-validate"

STATE="$ROOT/.fw/state.json"

echo "[fw-loop] project=$PROJECT"

echo "[fw-loop] Step 1: make patch"
"$MAKEPATCH"

echo "[fw-loop] Step 2: apply patch"
"$PATCH" "$PROJECT"

echo "[fw-loop] Step 3: validate"
"$VALIDATE"

if [[ -f "$STATE" ]]; then
  echo "[fw-loop] updating state"
  sed -i 's/"phase":.*/"phase": "loop_executed",/' "$STATE" || true
fi

echo "[fw-loop] DONE"
